{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mai-bu-mai",
  "compatibility_date": "2026-07-14",
  "main": "./worker/index.ts",
  "routes": [
    {
      "pattern": "mai.vigorxu.ac.cn",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
